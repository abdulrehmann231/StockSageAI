DATABASE_URL=postgresql+psycopg://stocksage:stocksage@localhost:5432/stocksage_test
REDIS_URL=redis://localhost:6379/15

JWT_SECRET=test-secret-not-used-anywhere-else
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:3000

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_NAME_ACCESS=access_token

# Effectively disabled for normal tests; the rate-limit-specific test
# overrides this via monkeypatch.
AUTH_RATE_LIMIT=1000/minute

LOG_LEVEL=WARNING
