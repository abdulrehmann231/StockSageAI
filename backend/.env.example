# Database (local docker-compose defaults; override with Supabase URL in prod)
DATABASE_URL=postgresql+psycopg://stocksage:stocksage@localhost:5432/stocksage

# Redis (local docker-compose; override with Upstash URL in prod)
REDIS_URL=redis://localhost:6379/0

# LLM Gateway
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Agent model overrides (optional — default to the free OpenRouter chain)
# NEWS_AGENT_MODEL=
# SENTIMENT_AGENT_MODEL=
# SENTIMENT_AGENT_FALLBACK_MODELS=

# Vector DB / Embeddings (Filings RAG) — NO API KEYS REQUIRED.
# Vectors live in Postgres via the pgvector extension (docker-compose uses the
# pgvector/pgvector image). Embeddings are computed locally on CPU; the model
# downloads once from HuggingFace. The service degrades to a deterministic
# hashing embedder if sentence-transformers isn't installed.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
# Some bge models retrieve better with a query instruction prefix; leave blank otherwise.
EMBEDDING_QUERY_PREFIX=
FILINGS_CACHE_TTL_SECONDS=21600

# SEC EDGAR requires a descriptive User-Agent (your app + contact email), NOT a key.
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=StockSage AI research bot (contact: you@example.com)

# Pinecone — DEPRECATED (replaced by pgvector). Unused; left for optional swap.
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=stocksage

# External Data APIs
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stocksage/0.1

# Sentiment Agent — extra social sources (all optional, all credential-free).
# Reddit works without the keys above via public JSON; those keys only upgrade it.
# Telegram is scraped from public t.me/s/<channel> previews (no Telethon needed).
# PSX_TELEGRAM_CHANNELS: comma-separated public channel handles (no @).
PSX_TELEGRAM_CHANNELS=psxstocks,pakistanstockexchange
# X/Twitter is best-effort. Set X_BEARER_TOKEN to use the official API; otherwise
# public Nitter mirrors are tried (flaky) and the source degrades to empty.
X_BEARER_TOKEN=
NITTER_INSTANCES=https://nitter.net,https://nitter.privacydev.net

# Email
RESEND_API_KEY=

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO
