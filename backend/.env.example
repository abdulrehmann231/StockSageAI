# Database (local docker-compose defaults; override with Supabase URL in prod)
DATABASE_URL=postgresql+psycopg://stocksage:stocksage@localhost:5432/stocksage

# Redis (local docker-compose; override with Upstash URL in prod)
REDIS_URL=redis://localhost:6379/0

# LLM Gateway
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Agent model overrides (optional — default to the free OpenRouter chain)
# NEWS_AGENT_MODEL=
# SENTIMENT_AGENT_MODEL=
# SENTIMENT_AGENT_FALLBACK_MODELS=

# Vector DB
PINECONE_API_KEY=
PINECONE_INDEX_NAME=stocksage
PINECONE_FILINGS_NAMESPACE_GLOBAL=sec_filings
PINECONE_FILINGS_NAMESPACE_PSX=psx_filings

# External Data APIs
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stocksage/0.1

# Sentiment Agent — extra social sources (all optional, all credential-free).
# Reddit works without the keys above via public JSON; those keys only upgrade it.
# Telegram is scraped from public t.me/s/<channel> previews (no Telethon needed).
# PSX_TELEGRAM_CHANNELS: comma-separated public channel handles (no @).
PSX_TELEGRAM_CHANNELS=psxstocks,pakistanstockexchange
# X/Twitter is best-effort. Set X_BEARER_TOKEN to use the official API; otherwise
# public Nitter mirrors are tried (flaky) and the source degrades to empty.
X_BEARER_TOKEN=
NITTER_INSTANCES=https://nitter.net,https://nitter.privacydev.net

# Email
RESEND_API_KEY=

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO
