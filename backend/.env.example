# Database (local docker-compose defaults; override with Supabase URL in prod)
DATABASE_URL=postgresql+psycopg://stocksage:stocksage@localhost:5432/stocksage

# Redis (local docker-compose; override with Upstash URL in prod)
REDIS_URL=redis://localhost:6379/0

# LLM Gateway
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Vector DB
PINECONE_API_KEY=
PINECONE_INDEX_NAME=stocksage
PINECONE_FILINGS_NAMESPACE_GLOBAL=sec_filings
PINECONE_FILINGS_NAMESPACE_PSX=psx_filings

# External Data APIs
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stocksage/0.1

# Email
RESEND_API_KEY=

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO
